# captain-mast ACL file
# Syntax is compatible with Mosquitto's acl_file format
#
# Important: in the current captain-mast broker engine this file is parsed but
# not yet enforced for publish/subscribe decisions. Authentication and mTLS are
# enforced; topic ACL enforcement still needs broker hooks or a different broker
# backend before this should be treated as a production security boundary.
#
# Directives:
#   topic [read|write|readwrite|none] <filter>
#   user <username>
#   pattern [read|write|readwrite|none] <filter>
#
# Wildcards: + (single level), # (zero or more levels)
# Pattern substitutions: %u (username), %c (client_id)
#
# Rules are checked in order: pattern → user-specific → global
# First match wins. Default is DENY.

# ── Global rules (apply to all authenticated users) ───────────────────────────

# Allow everyone to read broker system topics
topic read $SYS/#

# ── Per-user rules ─────────────────────────────────────────────────────────────

# Superuser — full access to all topics
user admin
topic readwrite #

# Read-only monitoring account
user monitor
topic read #

# ── Device pattern rules ───────────────────────────────────────────────────────
# Devices should authenticate with username = device serial.
# %u is replaced with the connecting username at match time.

pattern write   devices/%u/#
pattern write   status/%u
pattern read    commands/%u/#

# ── CR-One Edge firmware topic contract ────────────────────────────────────────
#
# cr-one-edge-fw currently documents this production MQTT contract:
#   publish   cr/heartbeat/{serial}
#   publish   cr/tap/{serial}
#   subscribe cr/tap-ack/{serial}

pattern write   cr/heartbeat/%u
pattern write   cr/tap/%u
pattern read    cr/tap-ack/%u

# ── Example named device ───────────────────────────────────────────────────────

user sensor-01
topic write sensors/sensor-01/temperature
topic write sensors/sensor-01/humidity
topic write status/sensor-01
topic read  commands/sensor-01/#

user cr-one-001
topic write cr/heartbeat/cr-one-001
topic write cr/tap/cr-one-001
topic read  cr/tap-ack/cr-one-001
